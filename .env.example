# Copy this file to .env for real model examples.
# The runtime itself does not require API keys.

# DeepSeek is OpenAI-compatible, so the example uses generic OPENAI_* names.
OPENAI_API_KEY=your_key_here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# Optional aliases also supported by build_model_from_env():
# DEEPSEEK_API_KEY=your_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
